<view class="container">
  <view class="tabs">
    <view class="tab-item {{currentTab === 0 ? 'active' : ''}}" bindtap="switchTab" data-tab="0">
      <text>创建词库</text>
    </view>
    <view class="tab-item {{currentTab === 1 ? 'active' : ''}}" bindtap="switchTab" data-tab="1">
      <text>我的词库</text>
    </view>
  </view>

  <view class="tab-content" wx:if="{{currentTab === 0}}">
    <view class="card">
      <view class="form-item">
        <text class="label">词库名称</text>
        <input class="input" placeholder="请输入词库名称" value="{{wordbookName}}" bindinput="onNameInput"></input>
      </view>
      
      <view class="form-item">
        <text class="label">分类</text>
        <picker mode="selector" range="{{grades}}" value="{{gradeIndex}}" bindchange="onGradeChange">
          <view class="picker">
            {{grades[gradeIndex]}}
          </view>
        </picker>
      </view>

      <view class="form-item">
        <text class="label">单元</text>
        <input class="input" placeholder="请输入单元（可选）" value="{{unit}}" bindinput="onUnitInput"></input>
      </view>
    </view>

    <view class="card">
      <view class="section-title flex-between">
        <text>添加词语</text>
        <button class="btn-small" bindtap="addWord">添加</button>
      </view>
      <input class="input" placeholder="请输入汉字或词语" value="{{newWord}}" bindinput="onWordInput"></input>
      
      <view class="word-list" wx:if="{{words.length > 0}}">
        <view class="word-item" wx:for="{{words}}" wx:key="*this">
          <text class="word-text">{{item}}</text>
          <text class="delete-btn" bindtap="removeWord" data-index="{{index}}">×</text>
        </view>
      </view>
    </view>

    <button class="btn btn-success" bindtap="saveWordbook" wx:if="{{words.length > 0}}">保存词库</button>
  </view>

  <view class="tab-content" wx:if="{{currentTab === 1}}">
    <view class="preset-section">
      <view class="preset-header">
        <text class="preset-title">📦 推荐词库</text>
        <text class="preset-subtitle">点击快速导入</text>
      </view>
      <scroll-view class="preset-scroll" scroll-x="true">
        <view class="preset-item" wx:for="{{presetWordbooks}}" wx:key="name" bindtap="importPreset" data-preset="{{item}}">
          <view class="preset-icon">
            <text>{{item.icon}}</text>
          </view>
          <text class="preset-name">{{item.name}}</text>
          <text class="preset-count">{{item.words.length}}个词</text>
        </view>
      </scroll-view>
    </view>

    <view class="wordbook-list" wx:if="{{wordbooks.length > 0}}">
      <view class="wordbook-item card" wx:for="{{wordbooks}}" wx:key="_id" bindtap="viewWordbook" data-id="{{item._id}}">
        <view class="wordbook-header">
          <view class="wordbook-icon chinese-icon">
            <text>📝</text>
          </view>
          <view class="wordbook-info">
            <text class="wordbook-name">{{item.name}}</text>
            <text class="wordbook-meta">{{item.words.length}}个词语 · {{formatDate(item.createTime)}}</text>
          </view>
        </view>
        
        <view class="wordbook-tags" wx:if="{{item.grade || item.unit}}">
          <text class="tag" wx:if="{{item.grade}}">{{item.grade}}</text>
          <text class="tag" wx:if="{{item.unit}}">{{item.unit}}</text>
        </view>
        
        <view class="wordbook-actions" catchtap="true">
          <button class="action-btn primary" bindtap="startDictation" data-id="{{item._id}}">
            听写
          </button>
          <button class="action-btn" bindtap="editWordbook" data-id="{{item._id}}">
            编辑
          </button>
        </view>
      </view>
    </view>

    <view class="empty-state" wx:else>
      <text class="empty-icon">📚</text>
      <text class="empty-text">还没有词库，快去创建一个吧！</text>
    </view>
  </view>
</view>
