.stats-card {
  text-align: center;
  padding: 50rpx 40rpx;
  margin-bottom: 24rpx;
}

.stat-number {
  font-size: 80rpx;
  font-weight: bold;
  background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  line-height: 1;
  margin-bottom: 12rpx;
}

.stat-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 24rpx;
}

.title-display {
  display: inline-flex;
  align-items: center;
  background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
  padding: 12rpx 30rpx;
  border-radius: 40rpx;
}

.title-icon {
  font-size: 32rpx;
  margin-right: 8rpx;
}

.title-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #d97706;
}

.medal-summary {
  display: flex;
  justify-content: space-around;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 24rpx;
  padding: 30rpx 20rpx;
  margin-bottom: 24rpx;
}

.summary-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.summary-emoji {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.summary-count {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 4rpx;
}

.summary-label {
  font-size: 22rpx;
  color: #999;
}

.next-milestone {
  margin-bottom: 30rpx;
}

.milestone-text {
  font-size: 26rpx;
  color: #666;
  text-align: center;
  margin-bottom: 16rpx;
}

.milestone-highlight {
  color: #f59e0b;
  font-weight: bold;
  font-size: 32rpx;
}

.milestone-title {
  color: #d97706;
  font-weight: 600;
}

.milestone-bar {
  width: 100%;
  height: 12rpx;
  background: #f3f4f6;
  border-radius: 6rpx;
  overflow: hidden;
}

.milestone-progress {
  height: 100%;
  background: linear-gradient(90deg, #f59e0b 0%, #d97706 100%);
  border-radius: 6rpx;
  transition: width 0.5s ease;
}

.medal-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.medal-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
}

.medal-emoji {
  font-size: 60rpx;
  margin-right: 20rpx;
}

.medal-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.medal-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 6rpx;
}

.medal-desc {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 4rpx;
}

.medal-time {
  font-size: 22rpx;
  color: #999;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: 8rpx;
}

.empty-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
}
