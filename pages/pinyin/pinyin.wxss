.tabs {
  display: flex;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 16rpx;
  padding: 8rpx;
  margin-bottom: 24rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  font-size: 28rpx;
  color: #666;
  border-radius: 12rpx;
  transition: background 0.3s ease, color 0.3s ease;
}

.tab-item.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  font-weight: 600;
}

.hint-box {
  background: linear-gradient(135deg, #ffecd2 0%, #fcb69f 100%);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  text-align: center;
}

.hint-text {
  font-size: 28rpx;
  color: #8b4513;
  font-weight: 500;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  flex-wrap: wrap;
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  flex-wrap: wrap;
  gap: 16rpx;
}

.pinyin-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.pinyin-item {
  width: 88rpx;
  height: 88rpx;
  background: #f7f8fa;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #333;
  transition: all 0.2s ease;
  border: 3rpx solid #e5e7eb;
  font-weight: bold;
  flex-shrink: 0;
}

.pinyin-item:active {
  background: #e5e7eb;
}

.pinyin-item.selected {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border-color: #667eea;
  box-shadow: 0 8rpx 20rpx rgba(102, 126, 234, 0.5);
}

.pinyin-item.disabled {
  opacity: 0.4;
  pointer-events: none;
}

.current-syllable {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(135deg, #a8edea 0%, #fed6e3 100%);
  border-radius: 16rpx;
  padding: 24rpx 32rpx;
  margin-bottom: 24rpx;
}

.current-syllable-text {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
}

.btn-add {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border-radius: 24rpx;
  padding: 16rpx 32rpx;
  font-size: 28rpx;
  border: none;
  font-weight: 500;
}

.action-buttons {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  flex-shrink: 0;
  align-items: flex-end;
}

.btn-small {
  padding: 10rpx 20rpx;
  font-size: 22rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border-radius: 20rpx;
  border: none;
  white-space: nowrap;
  line-height: 1.4;
}

.btn-small.btn-secondary {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
}

.syllable-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.syllable-tag-wrapper {
  display: flex;
  align-items: center;
  position: relative;
}

.syllable-tag {
  display: inline-block;
  padding: 12rpx 60rpx 12rpx 24rpx;
  background: linear-gradient(135deg, #e0e7ff 0%, #c7d2fe 100%);
  color: #4f46e5;
  border-radius: 30rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.syllable-delete {
  position: absolute;
  right: 8rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 36rpx;
  height: 36rpx;
  background: #ff6b6b;
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: bold;
  line-height: 1;
}

.add-btn {
  background: rgba(255, 255, 255, 0.9);
  border-radius: 24rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
  box-shadow: 0 10rpx 30rpx rgba(102, 126, 234, 0.1);
}

.add-icon {
  font-size: 40rpx;
  margin-right: 12rpx;
  color: #667eea;
}

.wordbook-item {
  margin-bottom: 20rpx;
  overflow: hidden;
}

.wordbook-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.wordbook-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 20rpx;
}

.pinyin-icon {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.wordbook-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.wordbook-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 6rpx;
}

.wordbook-meta {
  font-size: 24rpx;
  color: #999;
}

.wordbook-actions {
  display: flex;
  gap: 12rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f3f4f6;
}

.action-btn {
  flex: 1;
  padding: 16rpx;
  background: #f3f4f6;
  color: #666;
  border-radius: 12rpx;
  font-size: 26rpx;
  border: none;
}

.action-btn.primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
}

.preset-section {
  margin-bottom: 30rpx;
}

.preset-header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.preset-title {
  font-size: 30rpx;
  font-weight: bold;
  color: white;
}

.preset-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.preset-scroll {
  white-space: nowrap;
}

.preset-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  padding: 30rpx 24rpx;
  margin-right: 16rpx;
  width: 200rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}

.preset-item:last-child {
  margin-right: 0;
}

.preset-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.preset-name {
  font-size: 26rpx;
  color: #333;
  font-weight: 600;
  text-align: center;
  margin-bottom: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  width: 100%;
}

.preset-count {
  font-size: 22rpx;
  color: #999;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
}

.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 600rpx;
  padding: 40rpx;
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin-bottom: 30rpx;
}

.modal-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
}

.modal-actions .btn {
  flex: 1;
}
