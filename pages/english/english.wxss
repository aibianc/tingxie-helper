.tabs {
  display: flex;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 16rpx;
  padding: 8rpx;
  margin-bottom: 24rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  font-size: 28rpx;
  color: #666;
  border-radius: 12rpx;
  transition: all 0.3s ease;
}

.tab-item.active {
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
  color: white;
  font-weight: 600;
}

.form-item {
  margin-bottom: 30rpx;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  flex-wrap: wrap;
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  flex-wrap: wrap;
  gap: 16rpx;
}

.action-buttons {
  display: flex;
  gap: 12rpx;
  flex-shrink: 0;
}

.btn-small {
  padding: 10rpx 20rpx;
  font-size: 22rpx;
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
  color: white;
  border-radius: 20rpx;
  border: none;
  white-space: nowrap;
  line-height: 1.4;
}

.word-list {
  margin-top: 24rpx;
}

.word-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(135deg, #e0f2fe 0%, #bae6fd 100%);
  padding: 20rpx;
  border-radius: 16rpx;
  margin-bottom: 12rpx;
}

.word-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.word-text {
  font-size: 30rpx;
  color: #0369a1;
  font-weight: 500;
  margin-bottom: 4rpx;
}

.word-definition {
  font-size: 24rpx;
  color: #0891b2;
}

.delete-btn {
  width: 44rpx;
  height: 44rpx;
  background: #0369a1;
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  line-height: 1;
}

.wordbook-item {
  margin-bottom: 20rpx;
  overflow: hidden;
}

.wordbook-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.wordbook-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 20rpx;
}

.english-icon {
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
}

.wordbook-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.wordbook-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 6rpx;
}

.wordbook-meta {
  font-size: 24rpx;
  color: #999;
}

.wordbook-actions {
  display: flex;
  gap: 12rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f3f4f6;
}

.action-btn {
  flex: 1;
  padding: 16rpx;
  background: #f3f4f6;
  color: #666;
  border-radius: 12rpx;
  font-size: 26rpx;
  border: none;
}

.action-btn.primary {
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
  color: white;
}

.preset-section {
  margin-bottom: 30rpx;
}

.preset-header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.preset-title {
  font-size: 30rpx;
  font-weight: bold;
  color: white;
}

.preset-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.preset-scroll {
  white-space: nowrap;
}

.preset-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  padding: 30rpx 24rpx;
  margin-right: 16rpx;
  width: 200rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}

.preset-item:last-child {
  margin-right: 0;
}

.preset-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.preset-name {
  font-size: 26rpx;
  color: #333;
  font-weight: 600;
  text-align: center;
  margin-bottom: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  width: 100%;
}

.preset-count {
  font-size: 22rpx;
  color: #999;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
}
