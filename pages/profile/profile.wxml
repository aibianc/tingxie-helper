<view class="container">
  <view class="user-card card">
    <view class="user-avatar" wx:if="{{userInfo}}">
      <image src="{{userInfo.avatarUrl}}" mode="aspectFill"></image>
    </view>
    <view class="user-avatar placeholder" wx:else>
      <text>👤</text>
    </view>
    <view class="user-info">
      <text class="user-name">{{userInfo ? userInfo.nickName : '点击登录'}}</text>
      <text class="user-title" wx:if="{{userTitle}}">{{userTitle}}</text>
    </view>
    <button class="login-btn" wx:if="{{!userInfo}}" bindtap="doLogin">
      登录
    </button>
  </view>

  <view class="stats-grid">
    <view class="stat-card card">
      <text class="stat-emoji">📚</text>
      <text class="stat-number">{{stats.wordbooks}}</text>
      <text class="stat-label">词库</text>
    </view>
    <view class="stat-card card">
      <text class="stat-emoji">📋</text>
      <text class="stat-number">{{stats.dictations}}</text>
      <text class="stat-label">听写</text>
    </view>
    <view class="stat-card card">
      <text class="stat-emoji">🏆</text>
      <text class="stat-number">{{stats.medals}}</text>
      <text class="stat-label">奖牌</text>
    </view>
  </view>

  <view class="menu-list">
    <view class="menu-item card" bindtap="navigateTo" data-url="/pages/wordbooks/wordbooks">
      <view class="menu-left">
        <text class="menu-icon">📚</text>
        <text class="menu-text">我的词库</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>

    <view class="menu-item card" bindtap="navigateTo" data-url="/pages/history/history">
      <view class="menu-left">
        <text class="menu-icon">📋</text>
        <text class="menu-text">听写记录</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>

    <view class="menu-item card" bindtap="navigateTo" data-url="/pages/medals/medals">
      <view class="menu-left">
        <text class="menu-icon">🏆</text>
        <text class="menu-text">我的奖牌</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="section-title">设置</view>
  <view class="menu-list">
    <view class="menu-item card" bindtap="updateUserInfo" wx:if="{{userInfo}}">
      <view class="menu-left">
        <text class="menu-icon">👤</text>
        <text class="menu-text">个人信息</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>

    <view class="menu-item card" bindtap="clearCache">
      <view class="menu-left">
        <text class="menu-icon">🗑️</text>
        <text class="menu-text">清除缓存</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>

    <view class="menu-item card" bindtap="logout" wx:if="{{userInfo}}">
      <view class="menu-left">
        <text class="menu-icon">🚪</text>
        <text class="menu-text">退出登录</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="section-title">反馈与帮助</view>
  <view class="menu-list">
    <view class="menu-item card" bindtap="showFeedback">
      <view class="menu-left">
        <text class="menu-icon">💬</text>
        <text class="menu-text">意见反馈</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>

    <view class="menu-item card" bindtap="contactUs">
      <view class="menu-left">
        <text class="menu-icon">📧</text>
        <text class="menu-text">联系我们</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="about-card card">
    <text class="about-title">听写小助手</text>
    <text class="about-version">v1.0.0</text>
    <text class="about-desc">帮助孩子轻松学习拼音、汉字、英语单词</text>
  </view>
</view>

<!-- 反馈弹窗 -->
<view class="modal" wx:if="{{showFeedbackModal}}" bindtap="closeFeedback">
  <view class="modal-content card" catchtap="stopPropagation">
    <view class="modal-header">
      <text class="modal-title">意见反馈</text>
    </view>
    <textarea
      class="feedback-textarea"
      placeholder="请详细描述你的问题或建议，我们会认真对待每一条反馈~"
      value="{{feedbackText}}"
      bindinput="onFeedbackInput"
      maxlength="500"
      auto-height
    ></textarea>
    <view class="char-count">{{feedbackText.length}}/500</view>
    <view class="modal-actions">
      <button class="btn btn-secondary" bindtap="closeFeedback">取消</button>
      <button class="btn" bindtap="submitFeedback" disabled="{{!feedbackText.trim()}}">提交</button>
    </view>
  </view>
</view>

<!-- 编辑用户信息弹窗 -->
<view class="modal" wx:if="{{showEditModal}}" bindtap="closeEditModal">
  <view class="modal-content card" catchtap="stopPropagation">
    <view class="modal-header">
      <text class="modal-title">编辑个人信息</text>
    </view>
    
    <view class="edit-form">
      <view class="form-item">
        <text class="form-label">姓名</text>
        <input class="form-input" 
          placeholder="请输入姓名" 
          placeholder-style="color: #999; font-size: 30rpx"
          value="{{editingName}}"
          bindinput="onNameInput" 
          maxlength="20"
          focus="{{false}}"
          confirm-type="done" />
      </view>
      
      <view class="form-item">
        <text class="form-label">性别</text>
        <picker 
          mode="selector" 
          range="{{genderOptions}}" 
          value="{{editingGender}}" 
          bindchange="onGenderChange">
          <view class="form-picker">
            <text>{{genderOptions[editingGender]}}</text>
            <text class="picker-arrow">›</text>
          </view>
        </picker>
      </view>
    </view>
    
    <view class="modal-actions">
      <button class="btn btn-secondary" bindtap="closeEditModal">取消</button>
      <button class="btn" bindtap="saveUserInfo">保存</button>
    </view>
  </view>
</view>
